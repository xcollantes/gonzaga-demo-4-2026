{
  "rewrites": [
    {
      "source": "/",
      "destination": "/dashboard",
      "has": [
        {
          "type": "host",
          "value": "app.quantplex.ai"
        }
      ]
    },
    {
      "source": "/((?!api|_next|_static|favicon.ico).*)",
      "destination": "/$1",
      "has": [
        {
          "type": "host",
          "value": "app.quantplex.ai"
        }
      ]
    }
  ]
}
